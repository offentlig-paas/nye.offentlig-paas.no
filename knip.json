{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/app/**/page.{ts,tsx}",
    "src/app/**/layout.{ts,tsx}",
    "src/app/**/route.{ts,tsx}",
    "src/app/**/loading.{ts,tsx}",
    "src/app/**/*.mdx",
    "src/auth.ts",
    "src/server/root.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx,js,jsx}",
    "!src/**/*.test.{ts,tsx}",
    "!src/**/__tests__/**"
  ],
  "ignoreDependencies": ["@types/webpack-env", "@types/mdx", "postcss"],
  "next": {
    "entry": [
      "src/app/**/page.{ts,tsx}",
      "src/app/**/layout.{ts,tsx}",
      "src/app/**/route.{ts,tsx}",
      "src/app/**/loading.{ts,tsx}",
      "src/app/**/*.mdx"
    ]
  }
}
