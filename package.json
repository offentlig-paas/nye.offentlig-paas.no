{
  "name": "offentlig-paas",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --experimental-https --webpack",
    "prebuild": "tsx scripts/generate-logo-manifest.ts",
    "build": "next build",
    "generate:logos": "tsx scripts/generate-logo-manifest.ts",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "tsc --noEmit && eslint . --quiet && knip && prettier --write . --list-different && vitest run --reporter=dot",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "sanity": "sanity",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "postinstall": "simple-git-hooks"
  },
  "browserslist": "defaults, not ie <= 11",
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.3",
    "@sanity/client": "^7.20.0",
    "@sanity/image-url": "^2.1.1",
    "@slack/bolt": "^4.7.0",
    "@slack/web-api": "^7.15.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.98.0",
    "@tanstack/react-query-devtools": "^5.98.0",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webpack-env": "^1.18.8",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "feed": "^5.2.0",
    "groq": "^5.20.0",
    "next": "^16.2.3",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "styled-components": "^6.4.0",
    "superjson": "^2.2.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sanity/cli": "^6.3.1",
    "@sanity/vision": "^5.20.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdx": "^2.0.13",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.3",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "knip": "^6.4.1",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sanity": "^5.20.0",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.24.0",
  "simple-git-hooks": {
    "pre-commit": "pnpm run check"
  }
}
